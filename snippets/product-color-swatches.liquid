{%- comment -%}
  Renders cross-product image swatches linked to sibling products.

  Accepts:
  - product: {Object} The product to render swatches for
  - current_product_id: {Number} ID of the currently viewed product (to mark active swatch)

  Usage:
  {% render 'product-color-swatches', product: card_product, current_product_id: card_product.id %}
{%- endcomment -%}

{%- assign siblings = product.metafields.custom.color_siblings.value -%}

{%- if siblings != blank -%}
  <div class="product-color-swatches">
    {%- comment -%} Current product swatch {%- endcomment -%}
    <a
      href="{{ product.url }}"
      class="product-color-swatch{% if product.id == current_product_id %} product-color-swatch--active{% endif %}"
      title="{{ product.title | escape }}"
      aria-label="{{ product.title | escape }}"
    >
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 80 }}"
          alt="{{ product.title | escape }}"
          width="40"
          height="40"
          loading="lazy"
        >
      {%- endif -%}
    </a>

    {%- comment -%} Sibling product swatches {%- endcomment -%}
    {%- for sibling in siblings -%}
      <a
        href="{{ sibling.url }}"
        class="product-color-swatch{% if sibling.id == current_product_id %} product-color-swatch--active{% endif %}"
        title="{{ sibling.title | escape }}"
        aria-label="{{ sibling.title | escape }}"
      >
        {%- if sibling.featured_image -%}
          <img
            src="{{ sibling.featured_image | image_url: width: 80 }}"
            alt="{{ sibling.title | escape }}"
            width="40"
            height="40"
            loading="lazy"
          >
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
{%- endif -%}

<style>
  .product-color-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
    margin-bottom: 8px;
  }

  .product-color-swatch {
    display: block;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 3px solid #fff;
    outline: 1px solid rgba(0,0,0,0.2);
    overflow: hidden;
    flex-shrink: 0;
    transition: outline 0.2s;
  }

  .product-color-swatch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-color-swatch:hover,
  .product-color-swatch--active {
    outline: 2px solid #000;
  }
</style>
