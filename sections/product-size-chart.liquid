{%- liquid
  assign size_chart_raw = product.metafields.custom.size_chart.value
  assign unit           = section.settings.unit_label | default: 'kg'
  assign c1             = section.settings.col_1
  assign c2             = section.settings.col_2
  assign c3             = section.settings.col_3
  assign c4             = section.settings.col_4
  assign c5             = section.settings.col_5
  assign c6             = section.settings.col_6
-%}

{%- if size_chart_raw != blank -%}

{%- comment -%}
  Metafield format (multi_line_text_field):
    Each line = one measurement row.
    Values separated by  |
    Example:
      Waist  | 34 | 36 | 38
      Hip    | 51 | 53 | 55.5
      Length | 107 | 108 | 109
{%- endcomment -%}

{%- assign chart_lines = size_chart_raw | strip | newline_to_br | split: '<br />' -%}

<div class="mylia-size-chart section-{{ section.id }}-padding">
  <div class="mylia-size-chart__inner page-width">

    {%- if section.settings.show_trigger -%}
      <button
        class="mylia-size-chart__trigger"
        type="button"
        aria-expanded="false"
        aria-controls="SizeChart-{{ section.id }}"
      >
        <span class="mylia-size-chart__trigger-icon">
          {{- 'icon-ruler.svg' | inline_asset_content -}}
        </span>
        {{- section.settings.trigger_label | default: 'Size Chart' -}}
        <span class="mylia-size-chart__trigger-caret">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
    {%- endif -%}

    <div
      id="SizeChart-{{ section.id }}"
      class="mylia-size-chart__panel{% if section.settings.show_trigger %} mylia-size-chart__panel--collapsible{% endif %}"
    >
      <div class="mylia-size-chart__card">

        <div class="mylia-size-chart__header">
          <span class="mylia-size-chart__ornament" aria-hidden="true">&#10022;</span>
          <h2 class="mylia-size-chart__title">
            {{- section.settings.heading | default: 'Size Chart' -}}
          </h2>
          <span class="mylia-size-chart__divider" aria-hidden="true"></span>
        </div>

        <div class="mylia-size-chart__table-wrap">
          <table class="mylia-size-chart__table" role="table">
            <thead>
              <tr>
                <th scope="col"></th>
                {%- if c1 != blank -%}<th scope="col">{{ c1 }}</th>{%- endif -%}
                {%- if c2 != blank -%}<th scope="col">{{ c2 }}</th>{%- endif -%}
                {%- if c3 != blank -%}<th scope="col">{{ c3 }}</th>{%- endif -%}
                {%- if c4 != blank -%}<th scope="col">{{ c4 }}</th>{%- endif -%}
                {%- if c5 != blank -%}<th scope="col">{{ c5 }}</th>{%- endif -%}
                {%- if c6 != blank -%}<th scope="col">{{ c6 }}</th>{%- endif -%}
              </tr>
            </thead>
            <tbody>
              {%- for line in chart_lines -%}
                {%- assign line = line | strip | strip_html -%}
                {%- if line != blank -%}
                  {%- assign cells = line | split: '|' -%}
                  <tr>
                    <th scope="row">{{ cells[0] | strip }}</th>
                    {%- if c1 != blank -%}
                      {%- assign v = cells[1] | strip -%}
                      <td>{{ v }}{%- if v != blank -%}<span class="mylia-size-chart__unit"> {{ unit }}</span>{%- endif -%}</td>
                    {%- endif -%}
                    {%- if c2 != blank -%}
                      {%- assign v = cells[2] | strip -%}
                      <td>{{ v }}{%- if v != blank -%}<span class="mylia-size-chart__unit"> {{ unit }}</span>{%- endif -%}</td>
                    {%- endif -%}
                    {%- if c3 != blank -%}
                      {%- assign v = cells[3] | strip -%}
                      <td>{{ v }}{%- if v != blank -%}<span class="mylia-size-chart__unit"> {{ unit }}</span>{%- endif -%}</td>
                    {%- endif -%}
                    {%- if c4 != blank -%}
                      {%- assign v = cells[4] | strip -%}
                      <td>{{ v }}{%- if v != blank -%}<span class="mylia-size-chart__unit"> {{ unit }}</span>{%- endif -%}</td>
                    {%- endif -%}
                    {%- if c5 != blank -%}
                      {%- assign v = cells[5] | strip -%}
                      <td>{{ v }}{%- if v != blank -%}<span class="mylia-size-chart__unit"> {{ unit }}</span>{%- endif -%}</td>
                    {%- endif -%}
                    {%- if c6 != blank -%}
                      {%- assign v = cells[6] | strip -%}
                      <td>{{ v }}{%- if v != blank -%}<span class="mylia-size-chart__unit"> {{ unit }}</span>{%- endif -%}</td>
                    {%- endif -%}
                  </tr>
                {%- endif -%}
              {%- endfor -%}
            </tbody>
          </table>
        </div>

        {%- if section.settings.note != blank -%}
          <p class="mylia-size-chart__note">{{ section.settings.note }}</p>
        {%- endif -%}

      </div>
    </div>

  </div>
</div>

{%- endif -%}

{% style %}
  .mylia-size-chart {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .mylia-size-chart {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .mylia-size-chart__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mylia-size-chart__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: none;
    border: 0.1rem solid currentColor;
    padding: 1rem 2.4rem;
    font-size: 1.3rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    color: inherit;
    font-family: inherit;
    margin-bottom: 1.6rem;
    transition: opacity 0.2s;
  }

  .mylia-size-chart__trigger:hover { opacity: 0.65; }

  .mylia-size-chart__trigger-icon svg,
  .mylia-size-chart__trigger-caret svg {
    width: 1.6rem;
    height: 1.6rem;
  }

  .mylia-size-chart__trigger-caret { transition: transform 0.3s ease; }

  .mylia-size-chart__trigger[aria-expanded="true"] .mylia-size-chart__trigger-caret {
    transform: rotate(180deg);
  }

  .mylia-size-chart__panel--collapsible {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.35s ease;
    width: 100%;
  }

  .mylia-size-chart__panel--collapsible > .mylia-size-chart__card { min-height: 0; }

  .mylia-size-chart__panel--collapsible.is-open { grid-template-rows: 1fr; }

  .mylia-size-chart__card {
    background-color: #0d0d0d;
    color: #ffffff;
    padding: 4rem 3rem;
    width: 100%;
    max-width: 76rem;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .mylia-size-chart__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .mylia-size-chart__ornament {
    display: block;
    font-size: 1.4rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.8rem;
    letter-spacing: 0.4em;
  }

  .mylia-size-chart__title {
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 1.2rem;
    font-family: var(--font-heading-family, Georgia, serif);
  }

  .mylia-size-chart__divider {
    display: block;
    width: 4rem;
    height: 0.1rem;
    background: rgba(255,255,255,0.3);
    margin: 0 auto;
  }

  .mylia-size-chart__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mylia-size-chart__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1.4rem;
    min-width: 28rem;
  }

  .mylia-size-chart__table thead th {
    background-color: #1a1a1a;
    color: rgba(255,255,255,0.9);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 1.2rem;
    padding: 1.2rem 2rem;
    border: 0.1rem solid rgba(255,255,255,0.1);
    text-align: center;
    white-space: nowrap;
  }

  .mylia-size-chart__table thead th:first-child {
    background-color: transparent;
    border-color: transparent;
  }

  .mylia-size-chart__table tbody th,
  .mylia-size-chart__table tbody td {
    padding: 1.2rem 2rem;
    border: 0.1rem solid rgba(255,255,255,0.1);
    text-align: center;
  }

  .mylia-size-chart__table tbody th {
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    text-align: left;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .mylia-size-chart__table tbody td {
    color: rgba(255,255,255,0.8);
    font-weight: 600;
    font-size: 1.5rem;
  }

  .mylia-size-chart__table tbody tr:hover td,
  .mylia-size-chart__table tbody tr:hover th {
    background-color: rgba(255,255,255,0.05);
  }

  .mylia-size-chart__unit {
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,0.4);
  }

  .mylia-size-chart__note {
    margin-top: 2.4rem;
    font-size: 1.2rem;
    color: rgba(255,255,255,0.45);
    text-align: center;
    letter-spacing: 0.05em;
    font-family: var(--font-body-family, sans-serif);
  }
{% endstyle %}

<script>
  (function () {
    document.querySelectorAll('.mylia-size-chart__trigger').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        var panel = document.getElementById(this.getAttribute('aria-controls'));
        this.setAttribute('aria-expanded', String(!expanded));
        if (panel) panel.classList.toggle('is-open', !expanded);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Size Chart",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Add the size chart data to each product via Shopify Admin → Products → [product] → Metafields → custom.size_chart. One row per line, values separated by | e.g.: Waist | 34 | 36 | 38"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Size Chart"
    },
    {
      "type": "header",
      "content": "Size columns"
    },
    {
      "type": "paragraph",
      "content": "Column headers shown across the top. Leave a field blank to hide that column."
    },
    {
      "type": "text",
      "id": "col_1",
      "label": "Column 1",
      "default": "SMALL"
    },
    {
      "type": "text",
      "id": "col_2",
      "label": "Column 2",
      "default": "MEDIUM"
    },
    {
      "type": "text",
      "id": "col_3",
      "label": "Column 3",
      "default": "LARGE"
    },
    {
      "type": "text",
      "id": "col_4",
      "label": "Column 4 (optional)"
    },
    {
      "type": "text",
      "id": "col_5",
      "label": "Column 5 (optional)"
    },
    {
      "type": "text",
      "id": "col_6",
      "label": "Column 6 (optional)"
    },
    {
      "type": "header",
      "content": "Options"
    },
    {
      "type": "text",
      "id": "unit_label",
      "label": "Unit label",
      "default": "kg",
      "info": "Shown after each value. Leave blank to hide."
    },
    {
      "type": "checkbox",
      "id": "show_trigger",
      "label": "Collapsible (hidden until clicked)",
      "default": true
    },
    {
      "type": "text",
      "id": "trigger_label",
      "label": "Button label",
      "default": "Size Chart"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Footer note"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Size Chart"
    }
  ]
}
{% endschema %}
