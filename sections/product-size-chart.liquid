{%- assign size_chart = product.metafields.custom.size_chart.value -%}

{%- if size_chart != blank -%}
<div class="mylia-size-chart section-{{ section.id }}-padding">
  <div class="mylia-size-chart__inner page-width">

    {%- if section.settings.show_trigger -%}
      <button
        class="mylia-size-chart__trigger"
        type="button"
        aria-expanded="false"
        aria-controls="SizeChart-{{ section.id }}"
      >
        <span class="mylia-size-chart__trigger-icon">
          {{- 'icon-ruler.svg' | inline_asset_content -}}
        </span>
        {{ section.settings.trigger_label | default: 'Size Chart' }}
        <span class="mylia-size-chart__trigger-caret">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </button>
    {%- endif -%}

    <div
      id="SizeChart-{{ section.id }}"
      class="mylia-size-chart__panel{% if section.settings.show_trigger %} mylia-size-chart__panel--collapsible{% endif %}"
    >
      <div class="mylia-size-chart__card">
        <div class="mylia-size-chart__header">
          <span class="mylia-size-chart__ornament" aria-hidden="true">&#10022;</span>
          <h2 class="mylia-size-chart__title">{{ section.settings.heading | default: 'Size Chart' }}</h2>
          <span class="mylia-size-chart__divider" aria-hidden="true"></span>
        </div>

        {%- assign unit_label = section.settings.unit_label | default: 'kg' -%}

        <table class="mylia-size-chart__table" role="table">
          <thead>
            <tr>
              <th scope="col"></th>
              {%- for header in size_chart.headers -%}
                <th scope="col">{{ header }}</th>
              {%- endfor -%}
            </tr>
          </thead>
          <tbody>
            {%- for row in size_chart.rows -%}
              <tr>
                <th scope="row">{{ row.label }}</th>
                {%- for val in row.values -%}
                  <td>{{ val }} <span class="mylia-size-chart__unit">{{ unit_label }}</span></td>
                {%- endfor -%}
              </tr>
            {%- endfor -%}
          </tbody>
        </table>

        {%- if section.settings.note != blank -%}
          <p class="mylia-size-chart__note">{{ section.settings.note }}</p>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

<style>
  .mylia-size-chart {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .mylia-size-chart {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .mylia-size-chart__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mylia-size-chart__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: none;
    border: 0.1rem solid currentColor;
    padding: 1rem 2rem;
    font-size: 1.3rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    color: inherit;
    font-family: inherit;
    margin-bottom: 1.6rem;
    transition: opacity 0.2s;
  }

  .mylia-size-chart__trigger:hover {
    opacity: 0.7;
  }

  .mylia-size-chart__trigger-icon svg,
  .mylia-size-chart__trigger-caret svg {
    width: 1.6rem;
    height: 1.6rem;
  }

  .mylia-size-chart__trigger-caret {
    transition: transform 0.3s ease;
  }

  .mylia-size-chart__trigger[aria-expanded="true"] .mylia-size-chart__trigger-caret {
    transform: rotate(180deg);
  }

  .mylia-size-chart__panel--collapsible {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.35s ease;
    width: 100%;
  }

  .mylia-size-chart__panel--collapsible > .mylia-size-chart__card {
    min-height: 0;
  }

  .mylia-size-chart__panel--collapsible.is-open {
    grid-template-rows: 1fr;
  }

  .mylia-size-chart__card {
    background-color: #0d0d0d;
    color: #ffffff;
    padding: 4rem 3rem;
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    font-family: var(--font-heading-family, Georgia, serif);
  }

  .mylia-size-chart__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .mylia-size-chart__ornament {
    display: block;
    font-size: 1.4rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.8rem;
    letter-spacing: 0.4em;
  }

  .mylia-size-chart__title {
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 1.2rem;
  }

  .mylia-size-chart__divider {
    display: block;
    width: 4rem;
    height: 0.1rem;
    background: rgba(255,255,255,0.35);
    margin: 0 auto;
  }

  .mylia-size-chart__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1.4rem;
  }

  .mylia-size-chart__table thead tr th {
    background-color: #1a1a1a;
    color: rgba(255,255,255,0.85);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 1.2rem;
    padding: 1.2rem 1.6rem;
    border: 0.1rem solid rgba(255,255,255,0.1);
    text-align: center;
  }

  .mylia-size-chart__table thead tr th:first-child {
    background-color: transparent;
    border-color: transparent;
  }

  .mylia-size-chart__table tbody tr th,
  .mylia-size-chart__table tbody tr td {
    padding: 1.2rem 1.6rem;
    border: 0.1rem solid rgba(255,255,255,0.1);
    text-align: center;
  }

  .mylia-size-chart__table tbody tr th {
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    text-align: left;
    letter-spacing: 0.05em;
  }

  .mylia-size-chart__table tbody tr td {
    color: rgba(255,255,255,0.75);
    font-weight: 600;
    font-size: 1.5rem;
  }

  .mylia-size-chart__table tbody tr:hover td,
  .mylia-size-chart__table tbody tr:hover th {
    background-color: rgba(255,255,255,0.04);
  }

  .mylia-size-chart__unit {
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,0.45);
    margin-left: 0.2rem;
  }

  .mylia-size-chart__note {
    margin-top: 2rem;
    font-size: 1.2rem;
    color: rgba(255,255,255,0.5);
    text-align: center;
    letter-spacing: 0.05em;
    font-family: var(--font-body-family, sans-serif);
  }
</style>

<script>
  (function () {
    var triggers = document.querySelectorAll('.mylia-size-chart__trigger');
    triggers.forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        var panelId = this.getAttribute('aria-controls');
        var panel = document.getElementById(panelId);
        this.setAttribute('aria-expanded', String(!expanded));
        if (panel) panel.classList.toggle('is-open', !expanded);
      });
    });
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Size Chart",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Size chart data is pulled from the product metafield **custom.size_chart** (type: JSON). Format: { \"headers\": [\"S\",\"M\",\"L\"], \"rows\": [{ \"label\": \"Waist\", \"values\": [\"34\",\"36\",\"38\"] }] }"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Size Chart"
    },
    {
      "type": "checkbox",
      "id": "show_trigger",
      "label": "Show as collapsible (hidden by default)",
      "default": true
    },
    {
      "type": "text",
      "id": "trigger_label",
      "label": "Button label",
      "default": "Size Chart"
    },
    {
      "type": "text",
      "id": "unit_label",
      "label": "Unit label",
      "default": "kg",
      "info": "Shown after each measurement value (e.g. kg, cm, in)"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note below table",
      "info": "Optional footnote, e.g. 'All measurements are in kilograms'"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Size Chart"
    }
  ]
}
{% endschema %}
