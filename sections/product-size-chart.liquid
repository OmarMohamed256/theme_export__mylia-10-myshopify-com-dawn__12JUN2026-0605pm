{%- liquid
  assign size_chart_raw = product.metafields.custom.size_chart.value
  assign unit           = section.settings.unit_label | default: 'kg'
-%}

{%- if size_chart_raw != blank -%}

{%- comment -%}
  Metafield format — paste a plain table, first line = column headers:

    Area   | XS  | S   | M    | L    | XL
    Waist  | 60  | 65  | 70   | 75   | 80
    Hip    | 84  | 88  | 92   | 96   | 100
    Length | 95  | 96  | 97   | 98   | 99

  First line is parsed as the header row automatically.
  Any number of columns is supported — no customizer setup required.
{%- endcomment -%}

{%- assign all_lines = size_chart_raw | strip | newline_to_br | split: '<br />' -%}

{%- comment -%} Pull the first non-blank line as the header {%- endcomment -%}
{%- assign header_line = '' -%}
{%- for line in all_lines -%}
  {%- assign lc = line | strip | strip_html -%}
  {%- if lc != blank and header_line == '' -%}
    {%- assign header_line = lc -%}
  {%- endif -%}
{%- endfor -%}
{%- assign headers = header_line | split: '|' -%}

<div class="mylia-size-chart section-{{ section.id }}-padding">
  <div class="mylia-size-chart__inner page-width">

    {%- if section.settings.show_trigger -%}
      <button
        class="mylia-size-chart__trigger"
        type="button"
        aria-expanded="false"
        aria-controls="SizeChart-{{ section.id }}"
      >
        <span class="mylia-size-chart__trigger-icon">
          {{- 'icon-ruler.svg' | inline_asset_content -}}
        </span>
        {{- section.settings.trigger_label | default: 'Size Chart' -}}
        <span class="mylia-size-chart__trigger-caret">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
    {%- endif -%}

    <div
      id="SizeChart-{{ section.id }}"
      class="mylia-size-chart__panel{% if section.settings.show_trigger %} mylia-size-chart__panel--collapsible{% endif %}"
    >
      <div class="mylia-size-chart__card">

        <div class="mylia-size-chart__header">
          <span class="mylia-size-chart__ornament" aria-hidden="true">&#10022;</span>
          <h2 class="mylia-size-chart__title">
            {{- section.settings.heading | default: 'Size Chart' -}}
          </h2>
          <span class="mylia-size-chart__divider" aria-hidden="true"></span>
        </div>

        <div class="mylia-size-chart__table-wrap">
          <table class="mylia-size-chart__table" role="table">
            <thead>
              <tr>
                {%- for h in headers -%}
                  {%- assign hv = h | strip -%}
                  {%- if forloop.first -%}
                    <th scope="col" class="mylia-size-chart__row-header-label">{{ hv }}</th>
                  {%- else -%}
                    <th scope="col">{{ hv }}</th>
                  {%- endif -%}
                {%- endfor -%}
              </tr>
            </thead>
            <tbody>
              {%- assign first_done = false -%}
              {%- for line in all_lines -%}
                {%- assign lc = line | strip | strip_html -%}
                {%- if lc != blank -%}
                  {%- if first_done == false -%}
                    {%- comment -%} Skip the header line {%- endcomment -%}
                    {%- assign first_done = true -%}
                  {%- else -%}
                    {%- assign cells = lc | split: '|' -%}
                    <tr>
                      {%- for cell in cells -%}
                        {%- assign cv = cell | strip -%}
                        {%- if forloop.first -%}
                          <th scope="row">{{ cv }}</th>
                        {%- else -%}
                          <td>
                            {{- cv -}}
                            {%- if cv != blank and unit != blank -%}
                              <span class="mylia-size-chart__unit"> {{ unit }}</span>
                            {%- endif -%}
                          </td>
                        {%- endif -%}
                      {%- endfor -%}
                    </tr>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </tbody>
          </table>
        </div>

        {%- if section.settings.note != blank -%}
          <p class="mylia-size-chart__note">{{ section.settings.note }}</p>
        {%- endif -%}

      </div>
    </div>

  </div>
</div>

{%- endif -%}

{% style %}
  .mylia-size-chart {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .mylia-size-chart {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .mylia-size-chart__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mylia-size-chart__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: none;
    border: 0.1rem solid currentColor;
    padding: 1rem 2.4rem;
    font-size: 1.3rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    color: inherit;
    font-family: inherit;
    margin-bottom: 1.6rem;
    transition: opacity 0.2s;
  }

  .mylia-size-chart__trigger:hover { opacity: 0.65; }

  .mylia-size-chart__trigger-icon svg,
  .mylia-size-chart__trigger-caret svg {
    width: 1.6rem;
    height: 1.6rem;
  }

  .mylia-size-chart__trigger-caret { transition: transform 0.3s ease; }

  .mylia-size-chart__trigger[aria-expanded="true"] .mylia-size-chart__trigger-caret {
    transform: rotate(180deg);
  }

  .mylia-size-chart__panel--collapsible {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.35s ease;
    width: 100%;
  }

  .mylia-size-chart__panel--collapsible > .mylia-size-chart__card { min-height: 0; }

  .mylia-size-chart__panel--collapsible.is-open { grid-template-rows: 1fr; }

  .mylia-size-chart__card {
    background-color: #0d0d0d;
    color: #ffffff;
    padding: 4rem 3rem;
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .mylia-size-chart__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .mylia-size-chart__ornament {
    display: block;
    font-size: 1.4rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.8rem;
    letter-spacing: 0.4em;
  }

  .mylia-size-chart__title {
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 1.2rem;
    font-family: var(--font-heading-family, Georgia, serif);
  }

  .mylia-size-chart__divider {
    display: block;
    width: 4rem;
    height: 0.1rem;
    background: rgba(255,255,255,0.3);
    margin: 0 auto;
  }

  .mylia-size-chart__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mylia-size-chart__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1.4rem;
  }

  .mylia-size-chart__table thead th {
    background-color: #1a1a1a;
    color: rgba(255,255,255,0.9);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 1.2rem;
    padding: 1.2rem 2rem;
    border: 0.1rem solid rgba(255,255,255,0.1);
    text-align: center;
    white-space: nowrap;
  }

  .mylia-size-chart__table thead .mylia-size-chart__row-header-label {
    background-color: transparent;
    border-color: transparent;
    color: rgba(255,255,255,0.4);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .mylia-size-chart__table tbody th,
  .mylia-size-chart__table tbody td {
    padding: 1.2rem 2rem;
    border: 0.1rem solid rgba(255,255,255,0.1);
    text-align: center;
  }

  .mylia-size-chart__table tbody th {
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    text-align: left;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .mylia-size-chart__table tbody td {
    color: rgba(255,255,255,0.8);
    font-weight: 600;
    font-size: 1.5rem;
  }

  .mylia-size-chart__table tbody tr:hover td,
  .mylia-size-chart__table tbody tr:hover th {
    background-color: rgba(255,255,255,0.05);
  }

  .mylia-size-chart__unit {
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,0.4);
  }

  .mylia-size-chart__note {
    margin-top: 2.4rem;
    font-size: 1.2rem;
    color: rgba(255,255,255,0.45);
    text-align: center;
    letter-spacing: 0.05em;
    font-family: var(--font-body-family, sans-serif);
  }
{% endstyle %}

<script>
  (function () {
    document.querySelectorAll('.mylia-size-chart__trigger').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        var panel = document.getElementById(this.getAttribute('aria-controls'));
        this.setAttribute('aria-expanded', String(!expanded));
        if (panel) panel.classList.toggle('is-open', !expanded);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Size Chart",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Size chart data lives on each product: Shopify Admin → Products → [product] → Metafields → custom.size_chart. Paste a plain table — the first line is the header row, one row per line, values separated by |"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Size Chart"
    },
    {
      "type": "text",
      "id": "unit_label",
      "label": "Unit label",
      "default": "kg",
      "info": "Appended after each value. Leave blank to show no unit."
    },
    {
      "type": "checkbox",
      "id": "show_trigger",
      "label": "Collapsible (hidden until clicked)",
      "default": true
    },
    {
      "type": "text",
      "id": "trigger_label",
      "label": "Button label",
      "default": "Size Chart"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Footer note"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Size Chart"
    }
  ]
}
{% endschema %}
